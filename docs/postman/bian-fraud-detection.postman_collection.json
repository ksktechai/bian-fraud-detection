              ],
              "path": [
                "fraud-detection",
                "{{ref}}",
                "notify"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Escalated to the financial crime team.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "BIAN Notify \u2014 emit and log a fraud alert event."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ],
      "description": "The canonical happy path: initiate -> evaluate -> retrieve -> update -> notify."
