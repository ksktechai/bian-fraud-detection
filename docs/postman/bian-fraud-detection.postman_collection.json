{
  "info": {
    "_postman_id": "b1a0fd2e-4c7a-4d1e-9f3a-7c2e5a9d0011",
    "name": "bian-fraud-detection",
    "description": "BIAN Fraud Detection service domain. Uses {{baseUrl}} (default localhost:8080) and a {{ref}} collection variable. Requests that initiate a control record capture the returned referenceId into {{ref}} via a test script, so the following requests chain. The 'Evaluate scenarios' folders are self-contained (each seeds its own transaction, then evaluates it). Run folders top-to-bottom, or use the Collection Runner.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "localhost:8080",
      "type": "string"
    },
    {
      "key": "ref",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 Lifecycle (run in order)",
      "item": [
        {
          "name": "initiate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fraud-detection/initiate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fraud-detection",
                "initiate"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"TXN-DRAIN-001\",\n  \"amount\": 9000000.0,\n  \"type\": \"TRANSFER\",\n  \"nameOrig\": \"C840083671\",\n  \"nameDest\": \"C38997010\",\n  \"oldbalanceOrg\": 9000000.0,\n  \"newbalanceOrig\": 0.0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "BIAN Initiate \u2014 create a control record (status INITIATED) and capture referenceId."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('ref', pm.response.json().referenceId);",
                  "console.log('captured ref =', pm.collectionVariables.get('ref'));"
                ]
              }
            }
          ]
        },
        {
          "name": "evaluate",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fraud-detection/{{ref}}/evaluate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fraud-detection",
                "{{ref}}",
                "evaluate"
              ]
            },
            "description": "BIAN Evaluate \u2014 run AI triage (Gemini) and persist riskScore/decision/reasoning."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "pm.test('EVALUATED', () => pm.expect(pm.response.json().status).to.eql('EVALUATED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "retrieve",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fraud-detection/{{ref}}/retrieve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fraud-detection",
                "{{ref}}",
                "retrieve"
              ]
            },
            "description": "BIAN Retrieve \u2014 return the control record."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "update (analyst override)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fraud-detection/{{ref}}/update",
              "host": [
