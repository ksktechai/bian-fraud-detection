# =========================================================================
# bian-fraud-detection — environment variables
#
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# Quarkus loads ".env" from the project root automatically in dev/test, so
# no secret is ever stored in application.properties.
#
#   cp .env.example .env
# =========================================================================

# --- LLM provider selection (BUILD-TIME) ---------------------------------
# Which provider backs the FraudTriageAgent: "ai-gemini" (default) or "ollama".
# Both extensions are on the classpath; this is read at build time, so changing
# it needs a rebuild (in `quarkus:dev` a change triggers a live restart).
# LLM_PROVIDER=ai-gemini

# --- Google Gemini (used when LLM_PROVIDER=ai-gemini) ---------------------
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Default gemini-3.1-flash-lite has the most free quota (500/day). Higher-quality
# free options (20/day): gemini-3.5-flash, gemini-3-flash-preview, gemini-2.5-flash.
# Do NOT use gemini-2.0-flash on the free tier — it has zero free quota.
# GEMINI_MODEL=gemini-3.1-flash-lite

# --- Ollama (used when LLM_PROVIDER=ollama; no key) -----------------------
# Install Ollama (https://ollama.com), run `ollama pull qwen3:30b`, `ollama serve`.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen3:30b

# --- Optional: database (defaults match docker-compose.yml, host port 5434) ----
# DB_URL=jdbc:postgresql://localhost:5434/fraud
# DB_USER=fraud
# DB_PASSWORD=fraud

# --- Optional: dataset + logging -----------------------------------------
# DATASET_PATH=./data
# DATASET_MAX_ROWS=100000
# LOG_MAX_BODY=2000
