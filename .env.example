# =========================================================================
# bian-fraud-detection — environment variables
#
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# Quarkus loads ".env" from the project root automatically in dev/test, so
# no secret is ever stored in application.properties.
#
#   cp .env.example .env
# =========================================================================

# --- LLM provider: Google Gemini (active) --------------------------------
# The FraudTriageAgent (@RegisterAiService) runs on Gemini via
# quarkus-langchain4j-ai-gemini. Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Model id (default gemini-2.0-flash). Other options: gemini-2.5-flash, gemini-1.5-flash.
# GEMINI_MODEL=gemini-2.0-flash

# --- Alternative local provider: Ollama (no key) -------------------------
# Used only if you switch the provider back to Ollama (uncomment the Ollama
# dependency in pom.xml and the Ollama block in application.properties).
# Install Ollama (https://ollama.com), run `ollama pull qwen3:30b`, `ollama serve`.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen3:30b

# --- Optional: database (defaults match docker-compose.yml, host port 5434) ----
# DB_URL=jdbc:postgresql://localhost:5434/fraud
# DB_USER=fraud
# DB_PASSWORD=fraud

# --- Optional: dataset + logging -----------------------------------------
# DATASET_PATH=./data
# DATASET_MAX_ROWS=100000
# LOG_MAX_BODY=2000
